# ====== DashScope 通用配置 ======
DASHSCOPE_API_KEY=your_dashscope_api_key

# ====== TTS 语音合成 ======
TTS_PROVIDER=dashscope
TTS_MODEL=qwen3-tts-flash
TTS_VOICE=Cherry

# ====== ASR 语音识别 ======
ASR_PROVIDER=dashscope
ASR_MODEL=paraformer-realtime-v2

# ====== 视觉识别 ======
VISION_PROVIDER=dashscope
VISION_MODEL=qwen-vl-plus

# ====== 百炼（阿里云 AI）应用 ======
BAILIAN_API_KEY=your_bailian_api_key
# 新架构：两个独立的百炼应用
# BAILIAN_VISION_APP_ID: 挂视觉指纹知识库，用于语义检索匹配文物
BAILIAN_VISION_APP_ID=your_bailian_vision_app_id
# BAILIAN_QA_APP_ID: 不挂知识库，用于通用导游问答
BAILIAN_QA_APP_ID=your_bailian_qa_app_id
BAILIAN_APP_BASE_URL=https://dashscope.aliyuncs.com
BAILIAN_TIMEOUT=30

# ====== 文物视觉检索 ======
# local: 使用本地 museum_vision_candidates.json 特征词打分，最快
# hybrid: 本地高置信度直接返回，低置信度回退百炼视觉检索应用
# bailian: 始终调用百炼视觉检索应用
ARTIFACT_SEARCH_PROVIDER=local
ARTIFACT_LOCAL_MIN_CONFIDENCE=0.58
ARTIFACT_LOCAL_MIN_MARGIN=0.08

# ====== 扩展功能 ======
AUTO_TTS_BACKGROUND=true
ENABLE_DEBUG_ROUTES=false

# ====== 外部工具 ======
FFMPEG_BIN=ffmpeg
